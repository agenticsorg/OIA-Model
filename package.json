{
  "name": "oia-model-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:corpus": "node scripts/build-corpus.mjs",
    "build": "npm run build:corpus && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "echo \"(tests not yet authored; see plans/ADR-0001-oia-model-reader-ui.md §11 Phase 9)\" && exit 0",
    "feedback:list": "node scripts/feedback-list.mjs",
    "feedback:full": "node scripts/feedback-list.mjs --full",
    "feedback:query": "node scripts/feedback-query.mjs",
    "server:build": "npm run build:corpus && tsc -p tsconfig.server.json && printf '{\"type\":\"commonjs\"}\\n' > server-dist/package.json",
    "server:start": "node server-dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
