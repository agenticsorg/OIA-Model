{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "server-dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/db.ts", "server/handlers.ts", "server/index.ts"]
}
